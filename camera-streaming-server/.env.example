# ── Shared config loaded from common-properties/.env ─────────────────────────
# SOLACE_HOST, SOLACE_MQTT_PORT, SOLACE_VPN, SOLACE_USERNAME, SOLACE_PASSWORD
# TOPIC_VIDEO_FEED, TOPIC_ANALYTICS, TOPIC_FACE_MATCH
# ─────────────────────────────────────────────────────────────────────────────

# Solace PubSub+ MQTT Configuration (mapped from common-properties/.env)
SOLACE_MQTT_HOST=tcp://${SOLACE_HOST}:${SOLACE_MQTT_PORT}
SOLACE_USERNAME=${SOLACE_USERNAME}
SOLACE_PASSWORD=${SOLACE_PASSWORD}
SOLACE_CLIENT_ID=aeroswift-video-streamer

# Topics (mapped from common-properties/.env)
VIDEO_TOPIC=${TOPIC_VIDEO_FEED}
ANALYTICS_TOPIC=${TOPIC_ANALYTICS}
FACE_MATCH_TOPIC=${TOPIC_FACE_MATCH}

# ESP32 Camera Configuration
ESP32_CAMERA_IP=192.168.40.169
ESP32_STREAM_PORT=81
ESP32_STREAM_PATH=/stream

# Server Configuration
SERVER_PORT=3000
CHUNK_SIZE=8192
MIN_FRAME_INTERVAL_MS=0
MAX_FPS=10

# Face Detection Configuration
ENABLE_FACE_DETECTION=true
DETECTION_INTERVAL_MS=2000
DETECTION_CONFIDENCE_THRESHOLD=0.5
# Model type: yolov8n-face (YOLOv8 face detection) or face_detection_yunet_2023mar (OpenCV YuNet)
FACE_MODEL_TYPE=yolov8n-face

# Emotion Detection Configuration (requires face-api.js models)
ENABLE_EMOTION_DETECTION=true
