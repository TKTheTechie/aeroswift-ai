# Solace PubSub+ MQTT Configuration
SOLACE_MQTT_HOST=tcp://localhost:1883
SOLACE_USERNAME=default
SOLACE_PASSWORD=default
SOLACE_CLIENT_ID=gtaa-video-streamer

# ESP32 Camera Configuration
ESP32_CAMERA_IP=192.168.40.169
ESP32_STREAM_PORT=81
ESP32_STREAM_PATH=/stream

# Server Configuration
SERVER_PORT=3000
VIDEO_TOPIC=aeroswift/terminal1/camera/gate1
CHUNK_SIZE=8192
MIN_FRAME_INTERVAL_MS=0
MAX_FPS=10

# Face Detection Configuration
ENABLE_FACE_DETECTION=true
DETECTION_INTERVAL_MS=2000
DETECTION_CONFIDENCE_THRESHOLD=0.5
ANALYTICS_TOPIC=aeroswift/camera/analytics/gate1
# Model type: yolov8n-face (YOLOv8 face detection) or face_detection_yunet_2023mar (OpenCV YuNet)
FACE_MODEL_TYPE=yolov8n-face

# Emotion Detection Configuration (requires face-api.js models)
ENABLE_EMOTION_DETECTION=true