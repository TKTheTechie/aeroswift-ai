{
  "buildCommand": "npm run setup-faceapi && npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/qdrant/:path*", "destination": "https://ec2-18-206-222-103.compute-1.amazonaws.com/:path*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
