# ── Shared config loaded from common-properties/.env ─────────────────────────
# SOLACE_HOST, SOLACE_WS_PORT, SOLACE_VPN, SOLACE_USERNAME, SOLACE_PASSWORD
# TOPIC_VIDEO_FEED, TOPIC_ANALYTICS
# ─────────────────────────────────────────────────────────────────────────────

# Solace PubSub+ Configuration (VITE_ prefix required for client-side exposure)
# Values mapped from common-properties/.env via dotenv-expand
VITE_SOLACE_URL=ws://${SOLACE_HOST}:${SOLACE_WS_PORT}
VITE_SOLACE_VPN=${SOLACE_VPN}
VITE_SOLACE_USERNAME=${SOLACE_USERNAME}
VITE_SOLACE_PASSWORD=${SOLACE_PASSWORD}

# Application Topics (mapped from common-properties/.env)
VITE_VIDEO_TOPIC=${TOPIC_VIDEO_FEED}
VITE_ANALYTICS_TOPIC=${TOPIC_ANALYTICS}
VITE_FACE_MATCH_REQUEST_TOPIC=${TOPIC_FACE_MATCH_REQUEST}
VITE_FACE_MATCH_RESULT_TOPIC=${TOPIC_FACE_MATCH_RESULT}
VITE_PASSENGER_LOOKUP_REQUEST_TOPIC=${TOPIC_PASSENGER_LOOKUP_REQUEST}
VITE_PASSENGER_LOOKUP_RESPONSE_TOPIC=${TOPIC_PASSENGER_LOOKUP_RESPONSE}

# Demo Mode (set to 'true' to run without Solace connection)
VITE_DEMO_MODE=false
