# ── Shared config loaded from common-properties/.env ─────────────────────────
# SOLACE_HOST, SOLACE_WS_PORT, SOLACE_VPN, SOLACE_USERNAME, SOLACE_PASSWORD
# TOPIC_FACE_MATCH
# ─────────────────────────────────────────────────────────────────────────────

# Solace PubSub+ Connection (mapped from common-properties/.env)
SOLACE_URL=ws://${SOLACE_HOST}:${SOLACE_WS_PORT}
SOLACE_VPN=${SOLACE_VPN}
SOLACE_USERNAME=${SOLACE_USERNAME}
SOLACE_PASSWORD=${SOLACE_PASSWORD}

# Topic the camera-streaming-server publishes face frames to.
# A queue subscription on FACE_MATCH_QUEUE must attract this topic.
FACE_MATCH_QUEUE=FACE.MATCH.QUEUE

# Topic to publish match results back to (mapped from common-properties/.env)
FACE_MATCH_RESULT_TOPIC=${TOPIC_FACE_MATCH_RESULT}

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=flyers

# Face match confidence threshold (0–1)
MATCH_THRESHOLD=0.90
