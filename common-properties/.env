# ============================================================
# AeroSwift AI — Shared Environment Configuration
# ============================================================
# Copy this file to common-properties/.env and fill in your values.
# All subprojects load this file automatically at startup.
# Project-specific .env files may override any of these values.
# ============================================================

# ── Solace PubSub+ Broker ────────────────────────────────────
SOLACE_HOST=localhost
SOLACE_WS_PORT=8008
SOLACE_MQTT_PORT=1883
SOLACE_VPN=default
SOLACE_USERNAME=default
SOLACE_PASSWORD=default

# ── Topic Hierarchy ──────────────────────────────────────────
# Publisher and subscriber must use matching topic values.
TOPIC_VIDEO_FEED=aeroswift/terminal1/v1/camera/stream
TOPIC_ANALYTICS=aeroswift/terminal1/v1/camera/analytics
TOPIC_FACE_MATCH=aeroswift/terminal1/v1/face/match
